import logging

_logger = logging.getLogger(__name__)


def migrate(cr, version):
    """Post-migration: {{ migration_version }}."""
    if not version:
        return
{% for op in post_operations %}
{% if op.type == 'add_column' %}
    cr.execute(
        "ALTER TABLE {{ op.model | replace('.', '_') }} "
        "ADD COLUMN IF NOT EXISTS {{ op.new_name }} VARCHAR"
    )
    _logger.info("Added column {{ op.new_name }} to {{ op.model }}")
{% elif op.type == 'sql' %}
    cr.execute("{{ op.sql }}")
    _logger.info("Executed custom SQL")
{% endif %}
{% endfor %}
