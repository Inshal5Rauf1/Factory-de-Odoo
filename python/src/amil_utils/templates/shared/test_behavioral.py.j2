{# test_behavioral.py.j2 -- Independent behavioral smoke tests #}
# -*- coding: utf-8 -*-
"""Behavioral smoke tests \u2014 independent of generated test logic.

These tests verify that the module works correctly at runtime by probing
computed fields, workflow transitions, and access rules systematically.
"""
from odoo.tests.common import TransactionCase
from odoo.exceptions import AccessError


class TestBehavioralSmoke(TransactionCase):
    """Automated behavioral probes for {{ module_name }}."""

{% for model in models %}
    def test_{{ model.name | to_python_var }}_all_computes_run(self):
        """Verify all computed fields on {{ model.name }} execute without error."""
        record = self.env['{{ model.name }}'].create({{ model.get("test_create_vals", "{}") }})
{% for field in model.get("fields", []) %}
{% if field.get("compute") %}
        # Trigger compute for {{ field.name }}
        _ = record.{{ field.name }}
{% endif %}
{% endfor %}

{% if model.get("workflow_states") %}
    def test_{{ model.name | to_python_var }}_workflow_transitions(self):
        """Verify declared workflow transitions are callable."""
        record = self.env['{{ model.name }}'].create({{ model.get("test_create_vals", "{}") }})
{% for state in model.get("workflow_states", []) %}
{% if state.get("action_method") %}
        # Transition: {{ state.get("from", "any") }} -> {{ state.name }}
        if hasattr(record, '{{ state.action_method }}'):
            try:
                record.{{ state.action_method }}()
            except Exception:
                pass  # Some transitions may not be valid from current state
{% endif %}
{% endfor %}
{% endif %}

{% endfor %}
{% for role in security_roles %}
    def test_acl_{{ role.name | to_python_var }}_access(self):
        """Verify {{ role.name }} group can access declared models."""
        test_user = self.env['res.users'].create({
            'name': 'Test {{ role.name }}',
            'login': 'test_{{ role.name | to_python_var }}@example.com',
            'groups_id': [(6, 0, [self.env.ref('{{ module_technical_name }}.group_{{ role.xml_id }}').id])],
        })
{% for model in models %}
        # Verify read access to {{ model.name }}
        self.env['{{ model.name }}'].with_user(test_user).search([], limit=1)
{% endfor %}
{% endfor %}
