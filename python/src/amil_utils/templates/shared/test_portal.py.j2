    def test_portal_list_page(self):
        """Test portal list page is accessible."""
        self.authenticate("portal", "portal")
        response = self.url_open("/my/{{ model_xml_id }}s")
        self.assertEqual(response.status_code, 200)

    def test_portal_detail_page(self):
        """Test portal detail page is accessible."""
        self.authenticate("portal", "portal")
        response = self.url_open(f"/my/{{ model_xml_id }}/{self.test_record.id}")
        self.assertEqual(response.status_code, 200)
