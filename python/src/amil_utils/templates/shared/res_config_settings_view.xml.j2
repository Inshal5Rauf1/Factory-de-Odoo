<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.{{ module_name }}</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="{{ module_title }}" string="{{ module_title }}" data-key="{{ module_name }}">
                    <h2>{{ module_title }}</h2>
{% for setting in settings %}
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
{% if setting.type == 'Boolean' %}
                                <field name="{{ setting.name }}"/>
{% endif %}
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="{{ setting.name }}"/>
                                <div class="text-muted">{{ setting.description }}</div>
{% if setting.type != 'Boolean' %}
                                <div class="content-group">
                                    <field name="{{ setting.name }}"/>
                                </div>
{% endif %}
                            </div>
                        </div>
                    </div>
{% endfor %}
                </div>
            </xpath>
        </field>
    </record>
</odoo>
